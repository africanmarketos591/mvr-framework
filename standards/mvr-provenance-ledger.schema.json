{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://africanmarketos.com/standards/mvr-provenance-ledger.schema.json",
  "title": "MVR Provenance Ledger Item",
  "description": "Safe interoperability schema for provenance metadata attached to MVR evidence items. This is an exchange format, not the private MVR scoring algorithm.",
  "type": "object",
  "required": [
    "ledger_item_id",
    "source_family",
    "source_locator",
    "evidence_origin",
    "collection_method",
    "extraction_method",
    "extraction_confidence",
    "privacy_envelope",
    "created_at"
  ],
  "additionalProperties": false,
  "properties": {
    "ledger_item_id": {
      "type": "string",
      "minLength": 3,
      "description": "Stable local identifier for this provenance item."
    },
    "source_family": {
      "type": "string",
      "examples": ["trade_license", "mobile_money_statement", "field_note", "customer_order_log"]
    },
    "source_locator": {
      "type": "string",
      "description": "Human-readable source pointer. Do not include secrets or unnecessary personal data."
    },
    "source_hash_sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$",
      "description": "Optional SHA-256 hash of the normalized source material."
    },
    "evidence_origin": {
      "type": "string",
      "enum": ["field_research", "public_record", "platform_telemetry", "partner_attestation", "self_reported", "third_party_verification"]
    },
    "collection_method": {
      "type": "string",
      "enum": ["direct", "field_observation", "corporate_telemetry", "document_upload", "api_lookup", "manual_entry", "partner_export"]
    },
    "extraction_method": {
      "type": "string",
      "enum": ["human", "deterministic_parser", "ocr", "llm_assisted", "api_response", "csv_import"]
    },
    "extraction_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence_geography": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "country": {"type": "string", "pattern": "^[A-Z]{2}$"},
        "city": {"type": "string"},
        "region": {"type": "string"}
      }
    },
    "freshness_date": {
      "type": "string",
      "format": "date"
    },
    "privacy_envelope": {
      "type": "object",
      "required": [
        "contains_pii",
        "contains_sensitive_personal_data",
        "redaction_status",
        "safe_for_modeling"
      ],
      "additionalProperties": false,
      "properties": {
        "contains_pii": {"type": "boolean"},
        "contains_sensitive_personal_data": {"type": "boolean"},
        "consent_basis": {
          "type": "string",
          "enum": ["not_applicable", "consent", "contract", "legal_obligation", "legitimate_interest", "unknown"]
        },
        "retention_class": {
          "type": "string",
          "enum": ["session_only", "30d", "90d", "1y", "contractual", "unknown"]
        },
        "redaction_status": {
          "type": "string",
          "enum": ["raw", "minimized", "redacted", "aggregated", "synthetic"]
        },
        "safe_for_modeling": {"type": "boolean"}
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "attribution": {
      "type": "string",
      "const": "Minimum Viable Relationships (MVR), originated by Farouk Mark Mukiibi, African Market OS."
    }
  }
}

